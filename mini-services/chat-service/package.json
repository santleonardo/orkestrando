{
  "name": "@orkestrando/chat-service",
  "version": "1.0.0",
  "description": "Realtime chat service for ORKESTRANDO academic management system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn index.ts",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "generate": "prisma generate",
    "migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "socket.io": "^4.7.5",
    "@prisma/client": "^6.11.1",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.14.0",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/uuid": "^9.0.8",
    "prisma": "^6.11.1",
    "eslint": "^9.0.0"
  }
}
