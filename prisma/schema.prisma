// Orkestrando — Prisma Schema
// Módulo Professor: Calendário e Disponibilidade

generator client {
  provider = "prisma-client-js"
}

// Supabase PostgreSQL — para deploy no Vercel
// Set DATABASE_URL no Vercel com a connection string do Supabase:
//   postgresql://postgres.xxxx:SENHA@aws-0-region.pooler.supabase.com:6543/postgres
// Antes do deploy, rode supabase-setup.sql no SQL Editor do Supabase

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      String
  nome      String
  email     String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  turmasComoCoordenador Turma[]           @relation("TurmaCoordenador")
  materiasComoProfessor Materia[]         @relation("MateriaProfessor")
  disponibilidades      Disponibilidade[]
  aulasComoProfessor    Aula[]            @relation("AulaProfessor")
}

model Turma {
  id            String   @id @default(cuid())
  nome          String
  descricao     String?
  semestre      String
  ano           Int
  coordenadorId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  coordenador   Profile?  @relation("TurmaCoordenador", fields: [coordenadorId], references: [id], onDelete: SetNull)
  materias      Materia[]
  aulas         Aula[]
}

model Materia {
  id          String   @id @default(cuid())
  nome        String
  turmaId     String
  professorId String?
  createdAt   DateTime @default(now())

  turma       Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  professor   Profile? @relation("MateriaProfessor", fields: [professorId], references: [id], onDelete: SetNull)
  aulas       Aula[]
}

model Disponibilidade {
  id             String   @id @default(cuid())
  professorId    String
  diaSemana      Int
  horaInicio     String
  horaFim        String
  recorrente     Boolean  @default(false)
  dataEspecifica String?
  semestre       String
  ano            Int
  createdAt      DateTime @default(now())

  professor      Profile  @relation(fields: [professorId], references: [id], onDelete: Cascade)
}

model Aula {
  id              String   @id @default(cuid())
  materiaId       String
  professorId     String
  turmaId         String
  titulo          String
  descricao       String?
  dataHoraInicio  DateTime
  dataHoraFim     DateTime
  semestre        String
  ano             Int
  status          String   @default("agendada")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  materia         Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  professor       Profile  @relation("AulaProfessor", fields: [professorId], references: [id], onDelete: Cascade)
  turma           Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)
}
