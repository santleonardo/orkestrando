// ============================================
// ORKESTRANDO - Academic Management System
// Complete Prisma Schema for PostgreSQL
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  SUPER_ADMIN
  COORDINATOR
  PROFESSOR
  STUDENT
  ASSISTANT
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum MaterialType {
  PDF
  DOCX
  XLSX
  PPTX
  MP3
  MP4
  IMAGE
  ZIP
  OTHER
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  GRADED
  RETURNED
}

enum ConversationType {
  DIRECT
  GROUP
  ANNOUNCEMENT
}

enum SignatureType {
  OPEN_CLASS
  CLOSE_CLASS
  ATTENDANCE
}

enum SemesterStatus {
  ACTIVE
  INACTIVE
  UPCOMING
}

// ============================================
// 1. Organization (Organizacao)
// ============================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relations
  profiles              Profile[]
  courses               Course[]
  subjects              Subject[]
  rooms                 Room[]
  semesters             Semester[]
  teacherAvailabilities TeacherAvailability[]
  teacherBlocks         TeacherBlock[]
  holidays              Holiday[]
  classes               Class[]
  classSessions         ClassSession[]
  enrollments           Enrollment[]
  attendances           Attendance[]
  attendanceSignatures  AttendanceSignature[]
  materials             Material[]
  assignments           Assignment[]
  assignmentSubmissions AssignmentSubmission[]
  conversations         Conversation[]
  messages              Message[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  reports               Report[]
  sessionSettings       SessionSettings[]

  @@index([slug])
  @@map("organizations")
}

// ============================================
// 2. Profile (Perfil)
// ============================================

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  orgId     String   @map("org_id")
  role      Role     @default(STUDENT)
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relations
  organization            Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teacher                 Teacher?
  student                 Student?
  coordinator             Coordinator?
  rolePermissions         RolePermission[]           @relation("ProfileRolePermissions")
  attendanceSignatures    AttendanceSignature[]      @relation("ProfileSignatures")
  conversationParticipants ConversationParticipant[]
  sentMessages            Message[]                  @relation("MessageSender")
  notifications           Notification[]
  auditLogs               AuditLog[]
  uploadedMaterials       Material[]                 @relation("MaterialUploader")
  createdConversations    Conversation[]             @relation("ConversationCreator")

  @@unique([orgId, email])
  @@index([orgId, role])
  @@index([orgId, isActive])
  @@index([userId])
  @@map("profiles")
}

// ============================================
// 3. Permission (Permissao)
// ============================================

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  module      String

  /// Relations
  rolePermissions RolePermission[] @relation("PermissionRolePermissions")

  @@index([module])
  @@map("permissions")
}

// ============================================
// 4. RolePermission (PermissaoPapel)
// ============================================

model RolePermission {
  id           String  @id @default(uuid())
  roleId       Role
  permissionId String  @map("permission_id")
  profileId    String? @map("profile_id")

  /// Relations
  permission Permission @relation("PermissionRolePermissions", fields: [permissionId], references: [id], onDelete: Cascade)
  profile    Profile?   @relation("ProfileRolePermissions", fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId, profileId])
  @@index([roleId])
  @@index([permissionId])
  @@index([profileId])
  @@map("role_permissions")
}

// ============================================
// 5. Teacher (Professor)
// ============================================

model Teacher {
  id              String   @id @default(uuid())
  profileId       String   @unique @map("profile_id")
  department      String?
  specializations String[] @default([])
  hireDate        DateTime? @map("hire_date")
  bio             String?
  createdAt       DateTime @default(now()) @map("created_at")

  /// Relations
  profile               Profile               @relation(fields: [profileId], references: [id], onDelete: Cascade)
  teacherAvailabilities TeacherAvailability[]
  teacherBlocks         TeacherBlock[]
  classes               Class[]
  assignments           Assignment[]

  @@index([department])
  @@map("teachers")
}

// ============================================
// 6. Student (Aluno)
// ============================================

model Student {
  id               String   @id @default(uuid())
  profileId        String   @unique @map("profile_id")
  enrollmentNumber String   @map("enrollment_number")
  course           String?
  semester         Int?
  shift            String?
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")

  /// Relations
  profile               Profile                @relation(fields: [profileId], references: [id], onDelete: Cascade)
  enrollments           Enrollment[]
  attendances           Attendance[]
  assignmentSubmissions AssignmentSubmission[]

  @@index([enrollmentNumber])
  @@index([course])
  @@index([status])
  @@map("students")
}

// ============================================
// 7. Coordinator (Coordenador)
// ============================================

model Coordinator {
  id         String   @id @default(uuid())
  profileId  String   @unique @map("profile_id")
  department String?
  level      Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")

  /// Relations
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([department])
  @@map("coordinators")
}

// ============================================
// 8. Course (Curso)
// ============================================

model Course {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  name         String
  code         String
  description  String?
  duration     Int?
  totalCredits Int      @default(0) @map("total_credits")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subjects     Subject[]

  @@unique([orgId, code])
  @@index([orgId, isActive])
  @@map("courses")
}

// ============================================
// 9. Subject (Disciplina)
// ============================================

model Subject {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  courseId      String?  @map("course_id")
  name          String
  code          String
  description   String?
  credits       Int      @default(0)
  workload      Int      @default(0)
  semester      Int?
  isElective    Boolean  @default(false) @map("is_elective")
  isActive      Boolean  @default(true) @map("is_active")
  prerequisites String[] @default([])
  createdAt     DateTime @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  classes      Class[]
  materials    Material[]
  assignments  Assignment[]

  @@unique([orgId, code])
  @@index([orgId, courseId])
  @@index([orgId, isActive])
  @@index([orgId, semester])
  @@map("subjects")
}

// ============================================
// 10. Room (Sala)
// ============================================

model Room {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  code      String
  capacity  Int      @default(0)
  type      String   @default("CLASSROOM") // LAB, CLASSROOM, AUDITORIUM, STUDIO
  building  String?
  floor     Int?
  resources String[] @default([])
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  classes     Class[]

  @@unique([orgId, code])
  @@index([orgId, type])
  @@index([orgId, isActive])
  @@index([orgId, capacity])
  @@map("rooms")
}

// ============================================
// 11. Semester (Semestre)
// ============================================

model Semester {
  id        String         @id @default(uuid())
  orgId     String         @map("org_id")
  name      String
  startDate DateTime       @map("start_date")
  endDate   DateTime       @map("end_date")
  status    SemesterStatus @default(UPCOMING)
  createdAt DateTime       @default(now()) @map("created_at")

  /// Relations
  organization          Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teacherAvailabilities TeacherAvailability[]
  teacherBlocks         TeacherBlock[]
  classes               Class[]
  enrollments           Enrollment[]
  sessionSettings       SessionSettings[]

  @@index([orgId, status])
  @@index([orgId, startDate])
  @@index([startDate, endDate])
  @@map("semesters")
}

// ============================================
// 12. TeacherAvailability (DisponibilidadeProfessor)
// ============================================

model TeacherAvailability {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  teacherId  String   @map("teacher_id")
  semesterId String   @map("semester_id")
  weekday    Weekday
  startTime  String   @map("start_time") // HH:mm format
  endTime    String   @map("end_time")   // HH:mm format
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  semester    Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@index([orgId, teacherId])
  @@index([orgId, semesterId])
  @@index([teacherId, semesterId, weekday])
  @@unique([teacherId, semesterId, weekday, startTime, endTime])
  @@map("teacher_availabilities")
}

// ============================================
// 13. TeacherBlock (BloqueioProfessor)
// ============================================

model TeacherBlock {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  teacherId   String   @map("teacher_id")
  semesterId  String   @map("semester_id")
  date        DateTime
  startTime   String   @map("start_time") // HH:mm format
  endTime     String   @map("end_time")   // HH:mm format
  reason      String   // VACATION, MEETING, PERSONAL, MEDICAL, OTHER
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  semester    Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@index([orgId, teacherId])
  @@index([orgId, semesterId])
  @@index([teacherId, date])
  @@index([date])
  @@map("teacher_blocks")
}

// ============================================
// 14. Holiday (Feriado)
// ============================================

model Holiday {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  date      DateTime
  name      String
  type      String   @default("NATIONAL") // NATIONAL, LOCAL, INSTITUTIONAL
  createdAt DateTime @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, date])
  @@index([orgId, type])
  @@index([date])
  @@map("holidays")
}

// ============================================
// 15. Class (Turma)
// ============================================

model Class {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  subjectId       String   @map("subject_id")
  semesterId      String   @map("semester_id")
  teacherId       String   @map("teacher_id")
  roomId          String?  @map("room_id")
  name            String
  code            String
  schedule        Json     @default("[]") // Array of { weekday, startTime, endTime }
  maxStudents     Int      @default(0) @map("max_students")
  currentStudents Int      @default(0) @map("current_students")
  status          String   @default("ACTIVE") // ACTIVE, DROPPED, COMPLETED, FAILED
  createdAt       DateTime @default(now()) @map("created_at")

  /// Relations
  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  semester      Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  teacher       Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  room          Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  classSessions ClassSession[]
  enrollments   Enrollment[]
  materials     Material[]
  assignments   Assignment[]

  @@unique([orgId, code])
  @@index([orgId, subjectId])
  @@index([orgId, semesterId])
  @@index([orgId, teacherId])
  @@index([orgId, status])
  @@index([semesterId, teacherId])
  @@map("classes")
}

// ============================================
// 16. ClassSession (Aula)
// ============================================

model ClassSession {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  classId      String   @map("class_id")
  date         DateTime
  startTime    String   @map("start_time") // HH:mm format
  endTime      String   @map("end_time")   // HH:mm format
  topic        String?
  description  String?
  status       String   @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  teacherNotes String?  @map("teacher_notes")
  createdAt    DateTime @default(now()) @map("created_at")

  /// Relations
  organization          Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  class                 Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  attendances           Attendance[]
  attendanceSignatures  AttendanceSignature[]

  @@index([orgId, classId])
  @@index([classId, date])
  @@index([orgId, date])
  @@index([status])
  @@index([date])
  @@map("class_sessions")
}

// ============================================
// 17. Enrollment (Matricula)
// ============================================

model Enrollment {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  studentId  String    @map("student_id")
  classId    String    @map("class_id")
  semesterId String    @map("semester_id")
  status     String    @default("ACTIVE") // ACTIVE, DROPPED, COMPLETED, FAILED
  enrolledAt DateTime  @default(now()) @map("enrolled_at")
  droppedAt  DateTime? @map("dropped_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  semester    Semester      @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@unique([studentId, classId, semesterId])
  @@index([orgId, studentId])
  @@index([orgId, classId])
  @@index([orgId, semesterId])
  @@index([studentId, status])
  @@index([classId, status])
  @@map("enrollments")
}

// ============================================
// 18. Attendance (Frequencia)
// ============================================

model Attendance {
  id             String           @id @default(uuid())
  orgId          String           @map("org_id")
  classSessionId String           @map("class_session_id")
  studentId      String           @map("student_id")
  status         AttendanceStatus @default(ABSENT)
  notedBy        String?          @map("noted_by")
  notes          String?
  createdAt      DateTime         @default(now()) @map("created_at")

  /// Relations
  organization         Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  classSession         ClassSession           @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student              Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attendanceSignatures AttendanceSignature[]

  @@unique([classSessionId, studentId])
  @@index([orgId, classSessionId])
  @@index([orgId, studentId])
  @@index([studentId, status])
  @@index([classSessionId, status])
  @@map("attendances")
}

// ============================================
// 19. AttendanceSignature (AssinaturaFrequencia)
// ============================================

model AttendanceSignature {
  id             String        @id @default(uuid())
  orgId          String        @map("org_id")
  attendanceId   String        @map("attendance_id")
  classSessionId String        @map("class_session_id")
  signedBy       String        @map("signed_by")
  signatureType  SignatureType @default(ATTENDANCE) @map("signature_type")
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  device         String?
  createdAt      DateTime      @default(now()) @map("created_at")

  /// Relations
  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  attendance   Attendance             @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  classSession ClassSession           @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  profile      Profile                @relation("ProfileSignatures", fields: [signedBy], references: [id], onDelete: Cascade)

  @@index([orgId, attendanceId])
  @@index([orgId, classSessionId])
  @@index([signedBy])
  @@index([classSessionId, signatureType])
  @@map("attendance_signatures")
}

// ============================================
// 20. Material (Material)
// ============================================

model Material {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  subjectId   String       @map("subject_id")
  classId     String?      @map("class_id")
  uploadedBy  String       @map("uploaded_by")
  title       String
  description String?
  type        MaterialType @default(PDF)
  filePath    String       @map("file_path")
  fileSize    BigInt       @default(0) @map("file_size")
  version     Int          @default(1)
  isPublished Boolean      @default(false) @map("is_published")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  /// Relations
  organization     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subject          Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class            Class?       @relation(fields: [classId], references: [id], onDelete: SetNull)
  uploadedByProfile Profile      @relation("MaterialUploader", fields: [uploadedBy], references: [id])

  @@index([orgId, subjectId])
  @@index([orgId, classId])
  @@index([uploadedBy])
  @@index([orgId, type])
  @@index([isPublished])
  @@map("materials")
}

// ============================================
// 21. Assignment (Trabalho)
// ============================================

model Assignment {
  id          String           @id @default(uuid())
  orgId       String           @map("org_id")
  subjectId   String           @map("subject_id")
  classId     String           @map("class_id")
  createdBy   String           @map("created_by")
  title       String
  description String?
  dueDate     DateTime         @map("due_date")
  maxGrade    Decimal          @default(10.0) @db.Decimal(5, 2) @map("max_grade")
  status      AssignmentStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  /// Relations
  organization          Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subject               Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class                 Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdByTeacher      Teacher                 @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  assignmentSubmissions AssignmentSubmission[]

  @@index([orgId, subjectId])
  @@index([orgId, classId])
  @@index([createdBy])
  @@index([orgId, status])
  @@index([dueDate])
  @@map("assignments")
}

// ============================================
// 22. AssignmentSubmission (EntregaTrabalho)
// ============================================

model AssignmentSubmission {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  assignmentId String    @map("assignment_id")
  studentId    String    @map("student_id")
  filePath     String    @map("file_path")
  fileName     String    @map("file_name")
  fileSize     BigInt    @default(0) @map("file_size")
  grade        Decimal?  @db.Decimal(5, 2)
  feedback     String?
  submittedAt  DateTime  @default(now()) @map("submitted_at")
  gradedAt     DateTime? @map("graded_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignment  Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([orgId, assignmentId])
  @@index([orgId, studentId])
  @@index([studentId, submittedAt])
  @@map("assignment_submissions")
}

// ============================================
// 23. Conversation (Conversa)
// ============================================

model Conversation {
  id            String           @id @default(uuid())
  orgId         String           @map("org_id")
  type          ConversationType @default(DIRECT)
  title         String?
  createdBy     String?          @map("created_by")
  lastMessageAt DateTime?        @map("last_message_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  /// Relations
  organization      Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participants      ConversationParticipant[]
  messages          Message[]
  createdByProfile  Profile?                   @relation("ConversationCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orgId, type])
  @@index([lastMessageAt])
  @@index([createdBy])
  @@map("conversations")
}

// ============================================
// 24. ConversationParticipant (ParticipanteConversa)
// ============================================

model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  profileId      String    @map("profile_id")
  lastReadAt     DateTime? @map("last_read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  /// Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([conversationId, profileId])
  @@index([profileId])
  @@map("conversation_participants")
}

// ============================================
// 25. Message (Mensagem)
// ============================================

model Message {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  parentId       String?  @map("parent_id")
  createdAt      DateTime @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Profile      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  parent       Message?     @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies      Message[]    @relation("MessageThread")
  attachments  MessageAttachment[]

  @@index([orgId, conversationId])
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([parentId])
  @@index([createdAt])
  @@map("messages")
}

// ============================================
// 26. MessageAttachment (AnexoMensagem)
// ============================================

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  filePath   String   @map("file_path")
  fileName   String   @map("file_name")
  fileSize   BigInt   @default(0) @map("file_size")
  mimeType   String?  @map("mime_type")
  createdAt  DateTime @default(now()) @map("created_at")

  /// Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

// ============================================
// 27. Notification (Notificacao)
// ============================================

model Notification {
  id        String           @id @default(uuid())
  orgId     String           @map("org_id")
  profileId String           @map("profile_id")
  title     String
  content   String?
  type      NotificationType @default(INFO)
  data      Json             @default("{}")
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([orgId, profileId])
  @@index([profileId, isRead])
  @@index([orgId, type])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// 28. AuditLog (LogAuditoria)
// ============================================

model AuditLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  profileId  String?  @map("profile_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json     @default("{}")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  profile      Profile?     @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([orgId, action])
  @@index([orgId, resource])
  @@index([orgId, profileId])
  @@index([profileId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// 29. Report (Relatorio)
// ============================================

model Report {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  title       String
  type        String
  filters     Json     @default("{}")
  data        Json     @default("{}")
  generatedBy String   @map("generated_by")
  createdAt   DateTime @default(now()) @map("created_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, type])
  @@index([generatedBy])
  @@index([createdAt])
  @@map("reports")
}

// ============================================
// 30. SessionSettings (ConfiguracoesSessao)
// ============================================

model SessionSettings {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  semesterId   String   @map("semester_id")
  settingKey   String   @map("setting_key")
  settingValue Json     @default("{}") @map("setting_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  /// Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  semester    Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@unique([semesterId, settingKey])
  @@index([orgId, semesterId])
  @@index([orgId, settingKey])
  @@map("session_settings")
}
