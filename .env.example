# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key
NEXTAUTH_SECRET=your-nextauth-secret-key

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ORKESTRANDO

# -----------------------------------------------------------------------------
# Storage (Supabase Storage)
# -----------------------------------------------------------------------------
STORAGE_BUCKET=orkestrando-files
NEXT_PUBLIC_STORAGE_URL=https://your-project.supabase.co/storage/v1/object/public

# -----------------------------------------------------------------------------
# AI Integration (Optional)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4
AI_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Chat Service
# -----------------------------------------------------------------------------
CHAT_SERVICE_URL=http://localhost:3003
CHAT_PORT=3003
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Email (Optional)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@orkestrando.com
EMAIL_FROM_NAME=ORKESTRANDO

# -----------------------------------------------------------------------------
# File Storage Limits (in bytes)
# -----------------------------------------------------------------------------
MAX_AVATAR_SIZE=2097152
MAX_MATERIAL_SIZE=52428800
MAX_ASSIGNMENT_SIZE=26214400
MAX_MESSAGE_ATTACHMENT_SIZE=10485760

# -----------------------------------------------------------------------------
# Redis (Optional - for caching/sessions)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Vercel (set automatically in Vercel dashboard)
# -----------------------------------------------------------------------------
# VERCEL_URL=
# VERCEL_PROJECT_ID=
